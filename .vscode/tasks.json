// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "esbuild-watch",
      "problemMatcher": "$esbuild-watch",
      "isBackground": true,
      "runOptions": {
        "instancePolicy": "terminateOldest"
      },
      "presentation": {
        "reveal": "never",
        "close": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "webview-watch",
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "^.*"
        }
      },
      "isBackground": true,
      "runOptions": {
        "instancePolicy": "terminateOldest"
      },
      "presentation": {
        "reveal": "never",
        "close": true
      },
      "group": {
        "kind": "build"
      }
    },
    {
      "label": "debug:stop-watch-tasks",
      "type": "shell",
      "command": "echo Debug watch cleanup",
      "osx": {
        "command": "for pid in $(pgrep -f 'pnpm run webview-watch' || true); do kill -TERM -- -$pid 2>/dev/null || kill -TERM $pid 2>/dev/null || true; done; for pid in $(pgrep -f 'pnpm run esbuild-watch' || true); do kill -TERM -- -$pid 2>/dev/null || kill -TERM $pid 2>/dev/null || true; done"
      },
      "linux": {
        "command": "for pid in $(pgrep -f 'pnpm run webview-watch' || true); do kill -TERM -- -$pid 2>/dev/null || kill -TERM $pid 2>/dev/null || true; done; for pid in $(pgrep -f 'pnpm run esbuild-watch' || true); do kill -TERM -- -$pid 2>/dev/null || kill -TERM $pid 2>/dev/null || true; done"
      },
      "windows": {
        "command": "echo Debug watch cleanup is only configured for POSIX shells"
      },
      "runOptions": {
        "instancePolicy": "terminateOldest"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "close": true
      },
      "hide": true
    }
  ]
}
