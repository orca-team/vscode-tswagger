{
  "name": "@tswagger/core",
  "version": "1.0.0-beta.1",
  "private": false,
  "description": "Low-level tswagger generation primitives for integrations and tooling.",
  "license": "MIT",
  "repository": "https://github.com/orca-team/vscode-tswagger.git",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "pack:check": "pnpm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "test-compile": "node scripts/test-compile.js",
    "test": "mocha \"out-test/**/*.test.js\" --ui tdd --timeout 10000"
  },
  "dependencies": {
    "@tswagger/types": "workspace:*",
    "json-schema-to-typescript": "^12.0.0",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.7",
    "openapi-types": "^12.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^8.0.4",
    "@types/node": "^12.11.7",
    "esbuild": "^0.19.4",
    "glob": "^7.1.6",
    "mocha": "^8.2.1",
    "rimraf": "^5.0.5",
    "typescript": "^4.1.3"
  }
}
