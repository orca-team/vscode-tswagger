{
  "name": "@tswagger/cli",
  "version": "1.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "tswagger": "dist/bin.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "local-test:init": "node scripts/init-local-test.js",
