    "openapi-types": "^12.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^8.0.4",
    "@types/node": "^14.14.0",
    "esbuild": "^0.19.4",
    "glob": "^7.1.6",
    "mocha": "^8.2.1",
    "rimraf": "^5.0.5",
    "typescript": "^4.1.3"
  }
}